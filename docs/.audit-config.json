{
  "version": "1.0.0",
  "project": {
    "name": "template-v1",
    "type": "nextjs-bun",
    "description": "Enterprise Next.js starter template with audit system and design tokens"
  },
  "settings": {
    "failOnWarnings": false,
    "stopOnCritical": true,
    "generateReports": true,
    "outputDir": ".audit"
  },
  "layers": {
    "00-pre-flight": {
      "enabled": true,
      "requiredBunVersion": ">=1.0.0",
      "requiredFiles": ["package.json", "tsconfig.json", "biome.json", ".gitignore"],
      "requiredFolders": ["app", "components", "lib", "types", "styles", "scripts", "documentation"]
    },
    "01-doc-verification": {
      "enabled": true,
      "hashAlgorithm": "sha256",
      "excludePatterns": ["*.log", "*.tmp", "node_modules/**", ".next/**", ".git/**"]
    },
    "02-architecture": {
      "enabled": true,
      "enforceBoundaries": true,
      "allowedImports": {
        "app": ["components", "lib", "types", "styles"],
        "components": ["lib", "types", "styles"],
        "lib": ["types"],
        "types": [],
        "styles": []
      }
    },
    "03-typescript": {
      "enabled": true,
      "strictMode": true,
      "forbiddenPatterns": ["any", "Object", "Function", "console.log", "debugger"]
    },
    "04-design-tokens": {
      "enabled": true,
      "tokenPath": "styles/tokens.css",
      "forbiddenUnits": ["px"],
      "hardcodedValues": {
        "colors": ["#000", "#fff", "black", "white"],
        "sizes": ["0px", "1px"]
      }
    },
    "05-dependencies": {
      "enabled": true,
      "auditRegistry": true,
      "checkOutdated": true,
      "allowedLicenses": ["MIT", "Apache-2.0", "BSD-2-Clause", "BSD-3-Clause", "ISC"]
    },
    "06-git-health": {
      "enabled": true,
      "protectedBranches": ["main", "master"],
      "requirePR": true,
      "maxCommitMessageLength": 72
    },
    "07-ui-responsive": {
      "enabled": true,
      "breakpoints": {
        "mobile": "640px",
        "tablet": "768px",
        "desktop": "1024px"
      },
      "requireViewportMeta": true
    },
    "08-ownership": {
      "enabled": true,
      "codeownersFile": "CODEOWNERS",
      "requireOwnerOnAllFiles": true
    },
    "09-build-verify": {
      "enabled": true,
      "checkBuild": true,
      "checkBundleSize": true,
      "maxBundleSize": "1MB"
    }
  },
  "notifications": {
    "onFailure": ["console", "log"],
    "onWarning": ["console"],
    "onSuccess": ["console"]
  },
  "excludes": [
    "node_modules/**",
    ".next/**",
    ".git/**",
    "*.test.*",
    "*.spec.*",
    "coverage/**",
    "scripts/audit/**"
  ]
}
