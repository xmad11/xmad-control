# XMAD Control Platform - Path Configuration
# Last updated: 2026-03-14

# Project root (override with environment variable)
XMAD_CONTROL_ROOT=${XMAD_CONTROL_ROOT:-$HOME/xmad-control}

# Storage paths
XMAD_STORAGE=${XMAD_CONTROL_ROOT}/storage
XMAD_LOG_DIR=${XMAD_STORAGE}/logs
XMAD_BACKUP_DIR=${XMAD_STORAGE}/backups
XMAD_QUEUE_FILE=${XMAD_STORAGE}/automation/queue.json

# Module paths
XMAD_MODULES=${XMAD_CONTROL_ROOT}/modules
XMAD_CORE=${XMAD_MODULES}/core
XMAD_GUARDIAN=${XMAD_MODULES}/guardian
XMAD_MONITOR=${XMAD_MODULES}/monitor
XMAD_NETWORK=${XMAD_MODULES}/network
