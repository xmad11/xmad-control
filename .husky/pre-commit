#!/bin/bash
# Pre-commit corruption guard

echo "🔍 Checking for file corruption..."

# Check for invalid characters
if grep -rP "[\x00-\x08\x0B\x0C\x0E-\x1F]" components/ features/ runtime/ 2>/dev/null | grep -v "node_modules" | grep -q .; then
  echo "❌ Invalid characters detected in source files"
  grep -rP "[\x00-\x08\x0B\x0C\x0E-\x1F]" components/ features/ runtime/ 2>/dev/null | grep -v "node_modules"
  exit 1
fi

echo "✅ File integrity check passed"
