#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# PRE-COMMIT HOOK - Corruption Guard
# Prevents commits containing invisible characters that cause TS1128 errors
# ═══════════════════════════════════════════════════════════════════════════════

echo "🔍 Running pre-commit corruption guard..."

# Run the enhanced corruption check
bash scripts/check-corruption.sh

# Also run lint-staged for staged files
if command -v lint-staged &> /dev/null; then
  bun run lint-staged
fi

echo "✅ Pre-commit checks passed"
