{
  "version": 1,
  "profiles": {
    "zai": {
      "type": "api_key",
      "provider": "zai",
      "apiKey": "${ZAI_API_KEY}",
      "key": "${ZAI_API_KEY}"
    },
    "qwen-portal:qwen-cli": {
      "type": "oauth",
      "provider": "qwen-portal",
      "access": "${QWEN_ACCESS_TOKEN}",
      "refresh": "${QWEN_REFRESH_TOKEN}",
      "expires": 0
    }
  },
  "usageStats": {
    "zai": {
      "errorCount": 0,
      "lastUsed": 0,
      "lastFailureAt": 0
    }
  }
}
