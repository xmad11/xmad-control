{"type":"message","id":"570cca96","parentId":"108bb676","timestamp":"2026-03-11T16:25:48.003Z","message":{"role":"toolResult","toolCallId":"call_06ee9d7428e8484b8007ac53","toolName":"read","content":[{"type":"text","text":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n    <meta name=\"apple-mobile-web-app-capable\" content=\"yes\">\n    <meta name=\"mobile-web-app-capable\" content=\"yes\">\n    <title>XMAD Control Center v4.0</title>\n    <link rel=\"stylesheet\" href=\"styles.css\">\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n</head>\n<body>\n    <!-- Background -->\n    <div class=\"bg-gradient\"></div>\n    <div class=\"bg-grid\"></div>\n\n    <div class=\"app-container\">\n        <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\n             GLASSY HEADER\n             в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->\n        <header class=\"glass-header\" id=\"glassHeader\">\n            <div class=\"header-left\">\n                <button class=\"menu-toggle\" id=\"menuToggle\" onclick=\"toggleSideMenu()\">\n                    <span></span>\n                    <span></span>\n                    <span></span>\n                </button>\n                <div class=\"logo\">\n                    <span class=\"logo-icon\">вҡЎ</span>\n                    <span class=\"logo-text\">XMAD</span>\n                </div>\n            </div>\n            <div class=\"header-right\">\n                <button class=\"status-circle-btn\" onclick=\"toggleStatusModal()\" title=\"System Status\">\n                    <div class=\"status-indicator-ring\" id=\"headerStatusRing\"></div>\n                </button>\n            </div>\n        </header>\n\n        <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\n             SIDE MENU\n             в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->\n        <div class=\"side-menu-overlay\" id=\"sideMenuOverlay\" onclick=\"toggleSideMenu()\"></div>\n        <nav class=\"side-menu\" id=\"sideMenu\">\n            <div class=\"side-menu-header\">\n                <h2>Menu</h2>\n                <button class=\"close-menu-btn\" onclick=\"toggleSideMenu()\">Г—</button>\n            </div>\n            <div class=\"side-menu-content\">\n                <div class=\"menu-section\">\n                    <div class=\"menu-section-title\">Navigation</div>\n                    <div class=\"menu-item active\" onclick=\"showSection('dashboard'); toggleSideMenu();\">\n                        <span class=\"menu-item-icon\">рҹҸ </span>\n                        <span class=\"menu-item-text\">Workspace</span>\n                    </div>\n                    <div class=\"menu-item\" onclick=\"showSection('openclaw'); toggleSideMenu();\">\n                        <span class=\"menu-item-icon\">рҹҰҖ</span>\n                        <span class=\"menu-item-text\">OpenClaw</span>\n                    </div>\n                    <div class=\"menu-item\" onclick=\"showSection('guardian'); toggleSideMenu();\">\n                        <span class=\"menu-item-icon\">рҹӣЎпёҸ</span>\n                        <span class=\"menu-item-text\">Guardian</span>\n                    </div>\n                    <div class=\"menu-item\" onclick=\"showSection('network'); toggleSideMenu();\">\n                        <span class=\"menu-item-icon\">рҹҢҗ</span>\n                        <span class=\"menu-item-text\">Network</span>\n                    </div>\n                </div>\n\n                <div class=\"menu-section\">\n                    <div class=\"menu-section-title\">Tools</div>\n                    <div class=\"menu-item\" onclick=\"showSection('memory'); toggleSideMenu();\">\n                        <span class=\"menu-item-icon\">рҹ§ </span>\n                        <span class=\"menu-item-text\">Memory Editor</span>\n                    </div>\n                    <div class=\"menu-item\" onclick=\"showSection('backups'); toggleSideMenu();\">\n                        <span class=\"menu-item-icon\">рҹ’ҫ</span>\n                        <span class=\"menu-item-text\">Backups</span>\n                    </div>\n                    <div class=\"menu-item\" onclick=\"showSection('tasks'); toggleSideMenu();\">\n                        <span class=\"menu-item-icon\">вң…</span>\n                        <span class=\"menu-item-text\">All Tasks</span>\n                    </div>\n                    <div class=\"menu-item\" onclick=\"showSection('notes'); toggleSideMenu();\">\n                        <span class=\"menu-item-icon\">рҹ“қ</span>\n                        <span class=\"menu-item-text\">Notes</span>\n                    </div>\n                </div>\n\n                <div class=\"menu-section\">\n                    <div class=\"menu-section-title\">Documentation</div>\n                    <div class=\"menu-item\" onclick=\"openDoc('SSOT_API_KEYS_GUIDE')\">\n                        <span class=\"menu-item-icon\">рҹ”‘</span>\n                        <span class=\"menu-item-text\">SSOT API Keys</span>\n                    </div>\n                    <div class=\"menu-item\" onclick=\"openDoc('GUARDIAN_ORCHESTRATOR_GUIDE')\">\n                        <span class=\"menu-item-icon\">рҹӣЎпёҸ</span>\n                        <span class=\"menu-item-text\">Guardian Guide</span>\n                    </div>\n                    <div class=\"menu-item\" onclick=\"openDoc('XMAD_CONTROL_CENTER_GUIDE')\">\n                        <span class=\"menu-item-icon\">вҡЎ</span>\n                        <span class=\"menu-item-text\">XMAD Guide</span>\n                    </div>\n                    <div class=\"menu-item\" onclick=\"showSection('sshdocs'); toggleSideMenu();\">\n                        <span class=\"menu-item-icon\">рҹ“ұ</span>\n                        <span class=\"menu-item-text\">SSH Docs</span>\n                    </div>\n                    <div class=\"menu-item\" onclick=\"window.open('https://tailscale.com/kb', '_blank')\">\n                        <span class=\"menu-item-icon\">рҹҢҗ</span>\n                        <span class=\"menu-item-text\">Tailscale KB</span>\n                    </div>\n                </div>\n\n                <div class=\"menu-section\">\n                    <div class=\"menu-section-title\">System</div>\n                    <div class=\"menu-item\" onclick=\"runTool('sysinfo')\">\n                        <span class=\"menu-item-icon\">рҹ“Ҡ</span>\n                        <span class=\"menu-item-text\">System Info</span>\n                    </div>\n                    <div class=\"menu-item\" onclick=\"runTool('health-check')\">\n                        <span class=\"menu-item-icon\">рҹҸҘ</span>\n                        <span class=\"menu-item-text\">Health Check</span>\n                    </div>\n                    <div class=\"menu-item\" onclick=\"runTool('cleanup')\">\n                        <span class=\"menu-item-icon\">рҹ§№</span>\n                        <span class=\"menu-item-text\">Cleanup</span>\n                    </div>\n                </div>\n            </div>\n        </nav>\n\n        <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\n             MAIN CONTENT\n             в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->\n        <main class=\"main-content\">\n            <!-- WIDGETS ROW - Horizontal Scroll Only -->\n            <div class=\"widgets-row\" id=\"widgetsRow\">\n                <div class=\"mini-widget glow-cyan\" onclick=\"showSection('openclaw')\">\n                    <div class=\"widget-icon\">рҹҰҖ</div>\n                    <div class=\"widget-title\">OpenClaw</div>\n                    <div class=\"widget-value\" id=\"miniOpenClawStatus\">--</div>\n                    <div class=\"widget-status\">\n                        <span class=\"status-dot\" id=\"miniOpenClawDot\"></span>\n                        <span class=\"status-label\" id=\"miniOpenClawLabel\">...</span>\n                    </div>\n                </div>\n\n                <div class=\"mini-widget glow-purple\" onclick=\"showSection('guardian')\">\n                    <div class=\"widget-icon\">рҹӣЎпёҸ</div>\n                    <div class=\"widget-title\">Guardian</div>\n                    <div class=\"widget-value\" id=\"miniGuardianStatus\">--</div>\n                    <div class=\"widget-status\">\n                        <span class=\"status-dot\" id=\"miniGuardianDot\"></span>\n                        <span class=\"status-label\" id=\"miniGuardianLabel\">...</span>\n                    </div>\n                </div>\n\n                <div class=\"mini-widget glow-blue\" onclick=\"showSection('network')\">\n                    <div class=\"widget-icon\">рҹҢҗ</div>\n                    <div class=\"widget-title\">Tailscale</div>\n                    <div class=\"widget-value\" id=\"miniTailscaleIP\">--</div>\n                    <div class=\"widget-status\">\n                        <span class=\"status-dot\" id=\"miniTailscaleDot\"></span>\n                        <span class=\"status-label\" id=\"miniTailscaleLabel\">...</span>\n                    </div>\n                </div>\n\n                <div class=\"mini-widget glow-green\" onclick=\"showSection('network')\">\n                    <div class=\"widget-icon\">рҹ”җ</div>\n                    <div class=\"widget-title\">SSH</div>\n                    <div class=\"widget-value\">:22</div>\n                    <div class=\"widget-status\">\n                        <span class=\"status-dot\" id=\"miniSSHDot\"></span>\n                        <span class=\"status-label\" id=\"miniSSHLabel\">...</span>\n                    </div>\n                </div>\n\n                <div class=\"mini-widget glow-amber\">\n                    <div class=\"widget-icon\">рҹ’ҫ</div>\n                    <div class=\"widget-title\">Memory</div>\n                    <div class=\"widget-value\" id=\"miniMemoryUsage\">--</div>\n                    <div class=\"widget-status\">\n                        <span class=\"status-dot online\"></span>\n                        <span class=\"status-label\">Active</span>\n                    </div>\n                </div>\n\n                <div class=\"mini-widget glow-red\">\n                    <div class=\"widget-icon\">вҡЎ</div>\n                    <div class=\"widget-title\">CPU</div>\n                    <div class=\"widget-value\" id=\"miniCPUUsage\">--</div>\n                    <div class=\"widget-status\">\n                        <span class=\"status-dot online\"></span>\n                        <span class=\"status-label\">Normal</span>\n                    </div>\n                </div>\n            </div>\n\n\n[837 more lines in file. Use offset=201 to continue.]"}],"isError":false,"timestamp":1773246347716}}
