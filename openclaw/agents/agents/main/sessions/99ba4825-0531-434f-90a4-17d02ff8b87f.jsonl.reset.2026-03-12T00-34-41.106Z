{"type":"message","id":"afcc8392","parentId":"40cf6bb5","timestamp":"2026-03-11T16:25:58.659Z","message":{"role":"toolResult","toolCallId":"call_3f1334400fbb44659d44c871","toolName":"exec","content":[{"type":"text","text":"<!-- OpenClaw Section -->\n                <section id=\"section-openclaw\" class=\"section-content\" style=\"display:none;\">\n                    <div class=\"task-input-card\">\n                        <h3>рҹҰҖ OpenClaw Gateway</h3>\n                        <p style=\"font-size:0.7rem; color:var(--text-secondary); margin-bottom:0.75rem;\">AI-powered WhatsApp bot & orchestrator</p>\n                        <div style=\"display:flex; gap:0.4rem; flex-wrap:wrap;\">\n                            <button class=\"glass-btn primary\" onclick=\"startOpenClaw()\">в–¶ Start</button>\n                            <button class=\"glass-btn secondary\" onclick=\"stopOpenClaw()\">вҸ№ Stop</button>\n                            <button class=\"glass-btn ghost\" onclick=\"restartOpenClaw()\">рҹ”„ Restart</button>\n                        </div>\n                        <div style=\"margin-top:0.75rem; display:grid; grid-template-columns:repeat(2,1fr); gap:0.5rem; font-size:0.7rem;\">\n                            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                                <span style=\"color:var(--text-muted);\">Status:</span>\n                                <span id=\"ocDetailStatus\" style=\"color:var(--cyan-400);\">--</span>\n                            </div>\n                            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                                <span style=\"color:var(--text-muted);\">Memory:</span>\n                                <span id=\"ocDetailMemory\" style=\"color:var(--cyan-400);\">--</span>\n                            </div>\n                            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                                <span style=\"color:var(--text-muted);\">WhatsApp:</span>\n                                <span id=\"ocDetailWhatsApp\" style=\"color:var(--emerald-400);\">--</span>\n                            </div>\n                            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                                <span style=\"color:var(--text-muted);\">Watchdog:</span>\n                                <span id=\"ocDetailWatchdog\" style=\"color:var(--amber-400);\">--</span>\n                            </div>\n                        </div>\n                    </div>\n                </section>"}],"details":{"status":"completed","exitCode":0,"durationMs":244,"aggregated":"<!-- OpenClaw Section -->\n                <section id=\"section-openclaw\" class=\"section-content\" style=\"display:none;\">\n                    <div class=\"task-input-card\">\n                        <h3>рҹҰҖ OpenClaw Gateway</h3>\n                        <p style=\"font-size:0.7rem; color:var(--text-secondary); margin-bottom:0.75rem;\">AI-powered WhatsApp bot & orchestrator</p>\n                        <div style=\"display:flex; gap:0.4rem; flex-wrap:wrap;\">\n                            <button class=\"glass-btn primary\" onclick=\"startOpenClaw()\">в–¶ Start</button>\n                            <button class=\"glass-btn secondary\" onclick=\"stopOpenClaw()\">вҸ№ Stop</button>\n                            <button class=\"glass-btn ghost\" onclick=\"restartOpenClaw()\">рҹ”„ Restart</button>\n                        </div>\n                        <div style=\"margin-top:0.75rem; display:grid; grid-template-columns:repeat(2,1fr); gap:0.5rem; font-size:0.7rem;\">\n                            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                                <span style=\"color:var(--text-muted);\">Status:</span>\n                                <span id=\"ocDetailStatus\" style=\"color:var(--cyan-400);\">--</span>\n                            </div>\n                            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                                <span style=\"color:var(--text-muted);\">Memory:</span>\n                                <span id=\"ocDetailMemory\" style=\"color:var(--cyan-400);\">--</span>\n                            </div>\n                            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                                <span style=\"color:var(--text-muted);\">WhatsApp:</span>\n                                <span id=\"ocDetailWhatsApp\" style=\"color:var(--emerald-400);\">--</span>\n                            </div>\n                            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                                <span style=\"color:var(--text-muted);\">Watchdog:</span>\n                                <span id=\"ocDetailWatchdog\" style=\"color:var(--amber-400);\">--</span>\n                            </div>\n                        </div>\n                    </div>\n                </section>","cwd":"/Users/ahmadabdullah/.openclaw/workspace"},"isError":false,"timestamp":1773246358657}}
{"type":"message","id":"3c00b470","parentId":"afcc8392","timestamp":"2026-03-11T16:25:58.673Z","message":{"role":"toolResult","toolCallId":"call_c951aa35131947ae9718105f","toolName":"read","content":[{"type":"text","text":"                        <div id=\"activeTasksList\">\n                            <p class=\"empty-state\">No active tasks</p>\n                        </div>\n                    </div>\n                </section>\n\n                <!-- OpenClaw Section -->\n                <section id=\"section-openclaw\" class=\"section-content\" style=\"display:none;\">\n                    <div class=\"task-input-card\">\n                        <h3>рҹҰҖ OpenClaw Gateway</h3>\n                        <p style=\"font-size:0.7rem; color:var(--text-secondary); margin-bottom:0.75rem;\">AI-powered WhatsApp bot & orchestrator</p>\n                        <div style=\"display:flex; gap:0.4rem; flex-wrap:wrap;\">\n                            <button class=\"glass-btn primary\" onclick=\"startOpenClaw()\">в–¶ Start</button>\n                            <button class=\"glass-btn secondary\" onclick=\"stopOpenClaw()\">вҸ№ Stop</button>\n                            <button class=\"glass-btn ghost\" onclick=\"restartOpenClaw()\">рҹ”„ Restart</button>\n                        </div>\n                        <div style=\"margin-top:0.75rem; display:grid; grid-template-columns:repeat(2,1fr); gap:0.5rem; font-size:0.7rem;\">\n                            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                                <span style=\"color:var(--text-muted);\">Status:</span>\n                                <span id=\"ocDetailStatus\" style=\"color:var(--cyan-400);\">--</span>\n                            </div>\n                            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                                <span style=\"color:var(--text-muted);\">Memory:</span>\n                                <span id=\"ocDetailMemory\" style=\"color:var(--cyan-400);\">--</span>\n                            </div>\n                            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                                <span style=\"color:var(--text-muted);\">WhatsApp:</span>\n                                <span id=\"ocDetailWhatsApp\" style=\"color:var(--emerald-400);\">--</span>\n                            </div>\n                            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                                <span style=\"color:var(--text-muted);\">Watchdog:</span>\n                                <span id=\"ocDetailWatchdog\" style=\"color:var(--amber-400);\">--</span>\n                            </div>\n                        </div>\n                    </div>\n                </section>\n\n                <!-- Guardian Section -->\n                <section id=\"section-guardian\" class=\"section-content\" style=\"display:none;\">\n                    <div class=\"task-input-card\">\n                        <h3>рҹӣЎпёҸ Guardian Orchestrator</h3>\n                        <p style=\"font-size:0.7rem; color:var(--text-secondary); margin-bottom:0.75rem;\">Dual-mode auto-evolving system</p>\n                        <div style=\"display:flex; gap:0.4rem;\">\n                            <button class=\"glass-btn primary\" onclick=\"checkGuardian()\">рҹ”„ Check Health</button>\n                            <button class=\"glass-btn ghost\" onclick=\"openGuardianLogs()\">рҹ“ң Logs</button>\n                        </div>\n                        <div style=\"margin-top:0.75rem; font-size:0.7rem; color:var(--text-secondary);\">\n                            <div style=\"margin-bottom:0.25rem;\">рҹ“Ғ <code style=\"background:rgba(255,255,255,0.1); padding:0.15rem 0.4rem; border-radius:4px;\">~/.guardian-orchestrator-2026</code></div>\n                            <div>Modes: --suggest, --execute, --dry-run, --rollback</div>\n                        </div>\n                    </div>\n                </section>\n\n                <!-- Network Section -->\n                <section id=\"section-network\" class=\"section-content\" style=\"display:none;\">\n                    <div class=\"task-input-card\">\n                        <h3>рҹҢҗ Network & Access</h3>\n                        <div style=\"margin-top:0.75rem; display:flex; gap:0.5rem;\">\n                            <button class=\"glass-btn primary\" onclick=\"startTailscale()\">в–¶ Start VPN</button>\n                            <button class=\"glass-btn secondary\" onclick=\"stopTailscale()\">вҸ№ Stop VPN</button>\n                        </div>\n                        <div style=\"margin-top:0.75rem; font-size:0.7rem;\">\n                            <table style=\"width:100%;\">\n                                <tr><td style=\"color:var(--text-muted); padding:0.3rem;\">Host</td><td><code style=\"background:rgba(255,255,255,0.1); padding:0.15rem 0.4rem; border-radius:4px;\">100.121.254.21</code></td></tr>\n                                <tr><td style=\"color:var(--text-muted); padding:0.3rem;\">Port</td><td><code style=\"background:rgba(255,255,255,0.1); padding:0.15rem 0.4rem; border-radius:4px;\">22</code></td></tr>\n                                <tr><td style=\"color:var(--text-muted); padding:0.3rem;\">User</td><td><code style=\"background:rgba(255,255,255,0.1); padding:0.15rem 0.4rem; border-radius:4px;\">ahmadabdullah</code></td></tr>\n                            </table>\n                        </div>\n                        <button class=\"glass-btn ghost\" style=\"width:100%; margin-top:0.5rem;\" onclick=\"copyConnection()\">рҹ“Ӣ Copy Connection</button>\n                    </div>\n                </section>\n\n                <!-- Memory Section -->\n                <section id=\"section-memory\" class=\"section-content\" style=\"display:none;\">\n                    <div class=\"task-input-card\">\n                        <h3>рҹ§  Memory Editor</h3>\n                        <div style=\"display:flex; gap:0.4rem; margin:0.5rem 0;\">\n                            <input type=\"text\" class=\"glass-input\" id=\"memoryPath\" value=\"~/.guardian-orchestrator-2026/SOUL.md\">\n                        </div>\n                        <div style=\"display:flex; gap:0.4rem; margin-bottom:0.5rem;\">\n                            <button class=\"glass-btn primary\" onclick=\"loadMemory()\">рҹ“Ӯ Load</button>\n                            <button class=\"glass-btn secondary\" onclick=\"saveMemory()\">рҹ’ҫ Save</button>\n                        </div>\n                        <textarea class=\"glass-textarea\" id=\"memoryEditor\" style=\"min-height:200px;\"></textarea>\n                    </div>\n                </section>\n\n                <!-- Backups Section -->\n                <section id=\"section-backups\" class=\"section-content\" style=\"display:none;\">\n                    <div class=\"task-input-card\">\n                        <h3>рҹ’ҫ Backups</h3>\n                        <div style=\"display:flex; gap:0.4rem; margin:0.5rem 0;\">\n                            <button class=\"glass-btn primary\" onclick=\"createBackup()\">рҹ’ҫ Create</button>\n                            <button class=\"glass-btn ghost\" onclick=\"refreshBackups()\">рҹ”„ Refresh</button>\n                        </div>\n                        <div id=\"backupsList\" style=\"margin-top:0.5rem;\">\n                            <p class=\"empty-state\">No backups yet</p>\n                        </div>\n                    </div>\n                </section>\n\n[718 more lines in file. Use offset=320 to continue.]"}],"isError":false,"timestamp":1773246358663}}
{"type":"message","id":"971f7d28","parentId":"3c00b470","timestamp":"2026-03-11T16:26:36.093Z","message":{"role":"assistant","content":[{"type":"text","text":"Perfect! I can see the dashboard has OpenClaw controls and backup section. Now let me add the missing features. Let me create an updated version with chat, STT/TTS, and enhanced OpenClaw controls:"},{"type":"toolCall","id":"call_9e815af5ebf5426a8c56bde0","name":"write","arguments":{"content":"<!-- \n  ADD THIS TO THE OPENCLAW SECTION in index.html\n  Replace the existing OpenClaw section with this enhanced version\n-->\n\n<!-- Enhanced OpenClaw Section -->\n<section id=\"section-openclaw\" class=\"section-content\" style=\"display:none;\">\n    <!-- Controls -->\n    <div class=\"task-input-card\">\n        <h3>рҹҰҖ OpenClaw Gateway</h3>\n        <p style=\"font-size:0.7rem; color:var(--text-secondary); margin-bottom:0.75rem;\">\n            AI-powered WhatsApp bot & orchestrator | v2026.3.8\n        </p>\n        <div style=\"display:flex; gap:0.4rem; flex-wrap:wrap;\">\n            <button class=\"glass-btn primary\" onclick=\"startOpenClaw()\">в–¶ Start</button>\n            <button class=\"glass-btn secondary\" onclick=\"stopOpenClaw()\">вҸ№ Stop</button>\n            <button class=\"glass-btn ghost\" onclick=\"restartOpenClaw()\">рҹ”„ Restart</button>\n            <button class=\"glass-btn ghost\" onclick=\"optimizePC()\">рҹ’» Optimize</button>\n        </div>\n        <div style=\"margin-top:0.75rem; display:grid; grid-template-columns:repeat(2,1fr); gap:0.5rem; font-size:0.7rem;\">\n            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                <span style=\"color:var(--text-muted);\">Status:</span>\n                <span id=\"ocDetailStatus\" style=\"color:var(--cyan-400);\">--</span>\n            </div>\n            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                <span style=\"color:var(--text-muted);\">Memory:</span>\n                <span id=\"ocDetailMemory\" style=\"color:var(--cyan-400);\">--</span>\n            </div>\n            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                <span style=\"color:var(--text-muted);\">WhatsApp:</span>\n                <span id=\"ocDetailWhatsApp\" style=\"color:var(--emerald-400);\">--</span>\n            </div>\n            <div style=\"background:rgba(255,255,255,0.05); padding:0.5rem; border-radius:8px;\">\n                <span style=\"color:var(--text-muted);\">Watchdog:</span>\n                <span id=\"ocDetailWatchdog\" style=\"color:var(--amber-400);\">--</span>\n            </div>\n        </div>\n    </div>\n\n    <!-- Chat Interface -->\n    <div class=\"task-input-card\" style=\"margin-top:1rem;\">\n        <h3>рҹ’¬ Chat with Nova</h3>\n        <p style=\"font-size:0.7rem; color:var(--text-secondary); margin-bottom:0.75rem;\">\n            Direct chat via OpenClaw Gateway (Port 18789)\n        </p>\n        \n        <!-- Chat Messages -->\n        <div id=\"chatMessages\" style=\"height:300px; overflow-y:auto; background:rgba(0,0,0,0.2); border-radius:8px; padding:0.75rem; margin-bottom:0.5rem; font-size:0.8rem;\">\n            <p style=\"color:var(--text-muted); text-align:center; padding:2rem 0;\">\n                рҹ’¬ Start chatting with Nova...\n            </p>\n        </div>\n\n        <!-- Voice Controls -->\n        <div style=\"display:flex; gap:0.4rem; margin-bottom:0.5rem; align-items:center;\">\n            <button id=\"voiceRecordBtn\" class=\"glass-btn ghost\" onclick=\"toggleVoiceRecording()\" style=\"flex:0;\">\n                рҹҺӨ\n            </button>\n            <span id=\"voiceStatus\" style=\"font-size:0.7rem; color:var(--text-secondary);\">Click mic to speak</span>\n            <span id=\"voiceLanguage\" style=\"font-size:0.7rem; color:var(--text-muted); margin-left:auto;\">EN</span>\n        </div>\n\n        <!-- Input -->\n        <div style=\"display:flex; gap:0.4rem;\">\n            <input type=\"text\" class=\"glass-input\" id=\"chatInput\" placeholder=\"Type a message...\" style=\"flex:1;\" onkeypress=\"if(event.key==='Enter')sendChatMessage()\">\n            <button class=\"glass-btn primary\" onclick=\"sendChatMessage()\">Send</button>\n        </div>\n\n        <!-- Mode Toggle -->\n        <div style=\"margin-top:0.5rem; display:flex; gap:0.4rem; font-size:0.7rem;\">\n            <button class=\"chip-btn active\" id=\"modeWhatsApp\" onclick=\"setChatMode('whatsapp')\">\n                рҹ“ұ WhatsApp\n            </button>\n            <button class=\"chip-btn\" id=\"modeDirect\" onclick=\"setChatMode('direct')\">\n                рҹ’¬ Direct\n            </button>\n            <span style=\"margin-left:auto; color:var(--text-muted); padding:0.25rem 0.5rem;\">\n                Mode: <span id=\"currentChatMode\">WhatsApp</span>\n            </span>\n        </div>\n    </div>\n\n    <!-- Memory & Brain Viewer -->\n    <div class=\"task-input-card\" style=\"margin-top:1rem;\">\n        <h3>рҹ§  Nova's Brain</h3>\n        <div style=\"display:flex; gap:0.4rem; margin:0.5rem 0; flex-wrap:wrap;\">\n            <button class=\"chip-btn\" onclick=\"loadBrainFile('SOUL.md')\">рҹ“– SOUL</button>\n            <button class=\"chip-btn\" onclick=\"loadBrainFile('IDENTITY.md')\">рҹӘӘ IDENTITY</button>\n            <button class=\"chip-btn\" onclick=\"loadBrainFile('MEMORY.md')\">рҹ§  MEMORY</button>\n            <button class=\"chip-btn\" onclick=\"loadBrainFile('USER.md')\">рҹ‘Ө USER</button>\n        </div>\n        <textarea id=\"brainViewer\" class=\"glass-textarea\" style=\"min-height:150px; font-size:0.75rem; font-family:monospace;\" readonly placeholder=\"Select a brain file to view...\"></textarea>\n    </div>\n\n    <!-- Config Viewer -->\n    <div class=\"task-input-card\" style=\"margin-top:1rem;\">\n        <h3>вҡҷпёҸ Configuration</h3>\n        <button class=\"glass-btn ghost\" style=\"width:100%; margin-bottom:0.5rem;\" onclick=\"loadOpenClawConfig()\">рҹ“„ Load Config</button>\n        <textarea id=\"configViewer\" class=\"glass-textarea\" style=\"min-height:150px; font-size:0.7rem; font-family:monospace;\" readonly placeholder=\"Click 'Load Config' to view openclaw.json...\"></textarea>\n    </div>\n\n    <!-- Logs -->\n    <div class=\"task-input-card\" style=\"margin-top:1rem;\">\n        <h3>рҹ“ң Logs</h3>\n        <div style=\"display:flex; gap:0.4rem; margin:0.5rem 0;\">\n            <button class=\"chip-btn active\" onclick=\"loadLog('openclaw')\">OpenClaw</button>\n            <button class=\"chip-btn\" onclick=\"loadLog('gateway')\">Gateway</button>\n            <button class=\"chip-btn\" onclick=\"loadLog('watchdog')\">Watchdog</button>\n            <button class=\"glass-btn ghost\" style=\"margin-left:auto;\" onclick=\"refreshLogs()\">рҹ”„ Refresh</button>\n        </div>\n        <div id=\"logViewer\" style=\"height:200px; overflow-y:auto; background:rgba(0,0,0,0.3); border-radius:8px; padding:0.5rem; font-size:0.7rem; font-family:monospace; color:var(--text-muted);\">\n            Select a log file to view...\n        </div>\n    </div>\n\n    <!-- Backup & Restore -->\n    <div class=\"task-input-card\" style=\"margin-top:1rem;\">\n        <h3>рҹ’ҫ Backup & Restore</h3>\n        <div style=\"display:flex; gap:0.4rem; margin:0.5rem 0;\">\n            <button class=\"glass-btn primary\" onclick=\"backupOpenClaw()\">рҹ’ҫ Backup</button>\n            <button class=\"glass-btn secondary\" onclick=\"showRestoreDialog()\">рҹ“Ӯ Restore</button>\n            <button class=\"glass-btn ghost\" onclick=\"listBackups()\">рҹ“Ӣ List</button>\n        </div>\n        <div id=\"backupsList\" style=\"margin-top:0.5rem; font-size:0.75rem; color:var(--text-muted);\">\n            No backups available\n        </div>\n    </div>\n</section>\n\n<script>\n// Chat variables\nlet chatMode = 'whatsapp';\nlet isRecording = false;\nlet recognition = null;\n\n// Send chat message\nasync function sendChatMessage() {\n    const input = document.getElementById('chatInput');\n    const message = input.value.trim();\n    if (!message) return;\n\n    const chatDiv = document.getElementById('chatMessages');\n    \n    // Add user message\n    chatDiv.innerHTML += `<div style=\"text-align:right; margin:0.5rem 0;\"><span style=\"background:var(--primary-500); color:white; padding:0.5rem 0.75rem; border-radius:12px 12px 0 12px; display:inline-block; max-width:80%;\">${escapeHtml(message)}</span></div>`;\n    input.value = '';\n\n    try {\n        const response = await fetch('http://localhost:18789/api/message', {\n            method: 'POST',\n            headers: { 'Content-Type': 'application/json' },\n            body: JSON.stringify({\n                message: message,\n                channel: chatMode,\n                sessionKey: 'xmad-dashboard'\n            })\n        });\n        \n        const data = await response.json();\n        \n        // Add bot response\n        if (data.reply) {\n            chatDiv.innerHTML += `<div style=\"text-align:left; margin:0.5rem 0;\"><span style=\"background:rgba(255,255,255,0.1); padding:0.5rem 0.75rem; border-radius:12px 12px 12px 0; display:inline-block; max-width:80%;\">${escapeHtml(data.reply)}</span></div>`;\n        }\n        \n        chatDiv.scrollTop = chatDiv.scrollHeight;\n    } catch (error) {\n        chatDiv.innerHTML += `<div style=\"text-align:left; margin:0.5rem 0;\"><span style=\"background:rgba(239,68,68,0.2); color:var(--red-400); padding:0.5rem 0.75rem; border-radius:12px 12px 12px 0;\">Error: ${error.message}</span></div>`;\n    }\n}\n\n// Voice recording\nfunction toggleVoiceRecording() {\n    const btn = document.getElementById('voiceRecordBtn');\n    const status = document.getElementById('voiceStatus');\n    \n    if (!isRecording) {\n        // Start recording\n        isRecording = true;\n        btn.style.background = 'var(--red-500)';\n        btn.innerHTML = 'вҸ№';\n        status.textContent = 'Listening...';\n        \n        if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {\n            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;\n            recognition = new SpeechRecognition();\n            recognition.continuous = false;\n            recognition.interimResults = false;\n            recognition.lang = 'en-US';\n            \n            recognition.onresult = (event) => {\n                const transcript = event.results[0][0].transcript;\n                document.getElementById('chatInput').value = transcript;\n                status.textContent = 'вң“ Recorded';\n            };\n            \n            recognition.onerror = (event) => {\n                status.textContent = 'вқҢ Error: ' + event.error;\n                stopRecording();\n            };\n            \n            recognition.onend = () => {\n                stopRecording();\n            };\n            \n            recognition.start();\n        } else {\n            status.textContent = 'вқҢ STT not supported';\n            stopRecording();\n        }\n    } else {\n        // Stop recording\n        if (recognition) {\n            recognition.stop();\n        }\n        stopRecording();\n    }\n}\n\nfunction stopRecording() {\n    isRecording = false;\n    const btn = document.getElementById('voiceRecordBtn');\n    const status = document.getElementById('voiceStatus');\n    btn.style.background = '';\n    btn.innerHTML = 'рҹҺӨ';\n    if (status.textContent === 'Listening...') {\n        status.textContent = 'Click mic to speak';\n    }\n}\n\n// Set chat mode\nfunction setChatMode(mode) {\n    chatMode = mode;\n    document.getElementById('modeWhatsApp').classList.toggle('active', mode === 'whatsapp');\n    document.getElementById('modeDirect').classList.toggle('active', mode === 'direct');\n    document.getElementById('currentChatMode').textContent = mode === 'whatsapp' ? 'WhatsApp' : 'Direct';\n}\n\n// Load brain file\nasync function loadBrainFile(filename) {\n    try {\n        const response = await fetch(`/api/file/read?path=${encodeURIComponent(`~/.openclaw/workspace/${filename}`)}`);\n        const data = await response.json();\n        document.getElementById('brainViewer').value = data.content || 'File not found';\n    } catch (error) {\n        document.getElementById('brainViewer').value = 'Error loading file: ' + error.message;\n    }\n}\n\n// Load OpenClaw config\nasync function loadOpenClawConfig() {\n    try {\n        const response = await fetch(`/api/file/read?path=${encodeURIComponent('~/.openclaw/openclaw.json')}`);\n        const data = await response.json();\n        const config = JSON.parse(data.content);\n        document.getElementById('configViewer').value = JSON.stringify(config, null, 2);\n    } catch (error) {\n        document.getElementById('configViewer').value = 'Error loading config: ' + error.message;\n    }\n}\n\n// Load logs\nasync function loadLog(logType) {\n    const logPath = `~/.openclaw/logs/${logType}.log`;\n    try {\n        const response = await fetch(`/api/logs/read?path=${encodeURIComponent(logPath)}`);\n        const data = await response.json();\n        document.getElementById('logViewer').innerHTML = data.lines.map(line => \n            `<div style=\"margin:0.1rem 0; white-space:pre-wrap;\">${escapeHtml(line)}</div>`\n        ).join('');\n    } catch (error) {\n        document.getElementById('logViewer').innerHTML = `<div style=\"color:var(--red-400);\">Error: ${error.message}</div>`;\n    }\n}\n\n// Backup OpenClaw\nasync function backupOpenClaw() {\n    const chatDiv = document.getElementById('chatMessages');\n    chatDiv.innerHTML += `<div style=\"text-align:center; margin:0.5rem 0; color:var(--text-muted);\">вҸі Creating backup...</div>`;\n    \n    try {\n        const response = await fetch('/api/backups/create', { method: 'POST' });\n        const data = await response.json();\n        \n        if (data.ok) {\n            chatDiv.innerHTML += `<div style=\"text-align:center; margin:0.5rem 0; color:var(--emerald-400);\">вң… Backup created: ${data.backup}</div>`;\n            listBackups();\n        } else {\n            chatDiv.innerHTML += `<div style=\"text-align:center; margin:0.5rem 0; color:var(--red-400);\">вқҢ Backup failed: ${data.error}</div>`;\n        }\n    } catch (error) {\n        chatDiv.innerHTML += `<div style=\"text-align:center; margin:0.5rem 0; color:var(--red-400);\">вқҢ Error: ${error.message}</div>`;\n    }\n}\n\n// List backups\nasync function listBackups() {\n    try {\n        const response = await fetch('/api/backups/list');\n        const data = await response.json();\n        const list = document.getElementById('backupsList');\n        \n        if (data.backups && data.backups.length > 0) {\n            list.innerHTML = data.backups.map(b => \n                `<div style=\"padding:0.5rem; background:rgba(255,255,255,0.05); border-radius:8px; margin-bottom:0.25rem;\">\n                    <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n                        <span style=\"font-size:0.7rem;\">${b.name}</span>\n                        <button class=\"glass-btn ghost\" style=\"font-size:0.7rem; padding:0.25rem 0.5rem;\" onclick=\"restoreBackup('${b.name}')\">Restore</button>\n                    </div>\n                    <div style=\"font-size:0.65rem; color:var(--text-muted);\">${b.size} вҖў ${b.date}</div>\n                </div>`\n            ).join('');\n        } else {\n            list.innerHTML = 'No backups available';\n        }\n    } catch (error) {\n        document.getElementById('backupsList').innerHTML = 'Error loading backups';\n    }\n}\n\n// Optimize PC\nasync function optimizePC() {\n    const chatDiv = document.getElementById('chatMessages');\n    chatDiv.innerHTML += `<div style=\"text-align:center; margin:0.5rem 0; color:var(--text-muted);\">вҸі Optimizing PC...</div>`;\n    \n    try {\n        const response = await fetch('/api/optimize/run', { method: 'POST' });\n        const data = await response.json();\n        \n        if (data.ok) {\n            chatDiv.innerHTML += `<div style=\"text-align:center; margin:0.5rem 0; color:var(--emerald-400);\">вң… ${data.output}</div>`;\n        } else {\n            chatDiv.innerHTML += `<div style=\"text-align:center; margin:0.5rem 0; color:var(--red-400);\">вқҢ ${data.error}</div>`;\n        }\n    } catch (error) {\n        chatDiv.innerHTML += `<div style=\"text-align:center; margin:0.5rem 0; color:var(--red-400);\">вқҢ ${error.message}</div>`;\n    }\n}\n\n// Utility\nfunction escapeHtml(text) {\n    const div = document.createElement('div');\n    div.textContent = text;\n    return div.innerHTML;\n}\n</script>\n\n<style>\n.chip-btn {\n    background: rgba(255,255,255,0.05);\n    border: 1px solid rgba(255,255,255,0.1);\n    color: var(--text-secondary);\n    padding: 0.4rem 0.75rem;\n    border-radius: 20px;\n    font-size: 0.7rem;\n    cursor: pointer;\n    transition: all 0.2s;\n}\n\n.chip-btn:hover {\n    background: rgba(255,255,255,0.1);\n}\n\n.chip-btn.active {\n    background: var(--primary-500);\n    color: white;\n    border-color: var(--primary-500);\n}\n</style>\n","path":"/Users/ahmadabdullah/Desktop/xmad-control-center/ENHANCED_OPENCLAW_SECTION.html"}}],"api":"anthropic-messages","provider":"zai","model":"glm-4.7","usage":{"input":93795,"output":4206,"cacheRead":0,"cacheWrite":0,"totalTokens":98001,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773246358671}}
