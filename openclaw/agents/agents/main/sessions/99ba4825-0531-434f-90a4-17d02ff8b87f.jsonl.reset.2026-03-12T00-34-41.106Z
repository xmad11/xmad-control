{"type":"message","id":"44f81e99","parentId":"8826c8b6","timestamp":"2026-03-11T15:44:46.203Z","message":{"role":"toolResult","toolCallId":"call_e707c2ac9c554fd5b6fe31e6","toolName":"exec","content":[{"type":"text","text":"#!/bin/bash\n# ============================================================\n# OpenClaw Optimized Startup - SSOT Compliant\n# For: Mac with 8GB RAM\n# Features:\n# - Memory optimized (1.5GB limit)\n# - Auto-restart on crash\n# - SSOT key loading from Keychain\n# - Health checks\n# ============================================================\n\nset -e\n\n# Configuration\nOPENCLAW_DIR=\"$HOME/.openclaw\"\nLOG_FILE=\"$OPENCLAW_DIR/logs/startup.log\"\nPID_FILE=\"$OPENCLAW_DIR/openclaw.pid\"\nMAX_STARTUP_TIME=60\n\n# Colors for output\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nNC='\\033[0m'\n\n# Logging function\nlog() {\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $1\" | tee -a \"$LOG_FILE\"\n}\n\nlog \"рҹҡҖ OpenClaw Optimized Startup\"\nlog \"   Memory: 1.5GB limit\"\nlog \"   Config: SSOT compliant\"\n\n# в”Җв”Җв”Җ STEP 1: Load SSOT Keys from Keychain в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nlog \"рҹ”җ Loading SSOT API keys from Keychain...\"\n\nexport ZAI_API_KEY=$(security find-generic-password -s \"z.ai\" -a \"openclaw\" -w 2>/dev/null || echo \"\")\nexport GROQ_API_KEY=$(security find-generic-password -s \"SSOT_AI_GROQ\" -w 2>/dev/null || echo \"\")\nexport DEEPSEEK_API_KEY=$(security find-generic-password -s \"SSOT_AI_DEEPSEEK\" -w 2>/dev/null || echo \"\")\n\n# Verify primary key\nif [ -z \"$ZAI_API_KEY\" ]; then\n    log \"${RED}вқҢ ERROR: ZAI_API_KEY not found in Keychain${NC}\"\n    log \"   Add it with: security add-generic-password -a 'openclaw' -s 'z.ai' -w 'your-key'\"\n    exit 1\nfi\n\nlog \"${GREEN}вң“${NC} ZAI_API_KEY loaded (length: ${#ZAI_API_KEY})\"\nif [ -n \"$GROQ_API_KEY\" ]; then\n    log \"${GREEN}вң“${NC} GROQ_API_KEY loaded (length: ${#GROQ_API_KEY})\"\nfi\nif [ -n \"$DEEPSEEK_API_KEY\" ]; then\n    log \"${GREEN}вң“${NC} DEEPSEEK_API_KEY loaded\"\nfi\n\n# в”Җв”Җв”Җ STEP 2: Environment Setup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n# CRITICAL: Set PATH to include NVM node and bun BEFORE running openclaw\nexport PATH=\"$HOME/.nvm/versions/node/v22.16.0/bin:$HOME/.bun/bin:/usr/local/bin:/usr/bin:/bin:$PATH\"\nexport NODE_ENV=production\n# NODE_OPTIONS removed - OpenClaw handles memory internally via config\nexport OPENCLAW_HOST=127.0.0.1\nexport OPENCLAW_PORT=18789\n\n# Verify node is accessible\nif ! command -v node &> /dev/null; then\n    log \"${RED}вқҢ ERROR: node not found in PATH${NC}\"\n    exit 1\nfi\nlog \"${GREEN}вң“${NC} Node.js: $(node --version)\"\n\n# в”Җв”Җв”Җ STEP 3: Clean Up Old Processes в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nlog \"рҹ§№ Cleaning up old processes...\"\npkill -9 -f \"openclaw.*gateway\" 2>/dev/null || true\nsleep 2\n\n# Clear temp/cache files\nrm -rf \"$OPENCLAW_DIR/cache/\"* 2>/dev/null || true\nrm -rf \"$OPENCLAW_DIR/temp/\"* 2>/dev/null || true\n\n# в”Җв”Җв”Җ STEP 4: Start OpenClaw Gateway в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\ncd \"$OPENCLAW_DIR\" || exit 1\n\nlog \"рҹҡҖ Starting OpenClaw Gateway...\"\n\n# Use bun to run OpenClaw\nnohup ~/.bun/bin/openclaw gateway >> \"$OPENCLAW_DIR/logs/gateway.log\" 2>&1 &\n\nGATEWAY_PID=$!\necho \"$GATEWAY_PID\" > \"$PID_FILE\"\nlog \"   PID: $GATEWAY_PID\"\nlog \"   Port: 18789\"\n\n# в”Җв”Җв”Җ STEP 5: Wait for Startup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nlog \"вҸі Waiting for gateway to start...\"\n\nfor i in $(seq 1 $MAX_STARTUP_TIME); do\n    # Check if process is still running\n    if ! ps -p $GATEWAY_PID > /dev/null 2>&1; then\n        log \"${RED}вқҢ Process died during startup${NC}\"\n        log \"   Last 20 log lines:\"\n        tail -20 \"$OPENCLAW_DIR/logs/gateway.log\" 2>/dev/null || true\n        exit 1\n    fi\n\n    # Check if port is listening\n    if lsof -i :18789 > /dev/null 2>&1; then\n        MEM=$(ps -o rss= -p $GATEWAY_PID 2>/dev/null | awk '{print int($1/1024)}')\n        log \"${GREEN}вң… Gateway started successfully!${NC}\"\n        log \"   Memory: ${MEM}MB\"\n        log \"   Port: 18789\"\n        log \"   Config: Optimized for 8GB RAM\"\n        exit 0\n    fi\n\n    echo -n \".\"\n    sleep 1\ndone\n\n# Timeout\nlog \"\"\nlog \"${RED}вқҢ Gateway failed to start within ${MAX_STARTUP_TIME}s${NC}\"\nlog \"   Last 20 log lines:\"\ntail -20 \"$OPENCLAW_DIR/logs/gateway.log\" 2>/dev/null || true\nkill -9 $GATEWAY_PID 2>/dev/null || true\nexit 1"}],"details":{"status":"completed","exitCode":0,"durationMs":204,"aggregated":"#!/bin/bash\n# ============================================================\n# OpenClaw Optimized Startup - SSOT Compliant\n# For: Mac with 8GB RAM\n# Features:\n# - Memory optimized (1.5GB limit)\n# - Auto-restart on crash\n# - SSOT key loading from Keychain\n# - Health checks\n# ============================================================\n\nset -e\n\n# Configuration\nOPENCLAW_DIR=\"$HOME/.openclaw\"\nLOG_FILE=\"$OPENCLAW_DIR/logs/startup.log\"\nPID_FILE=\"$OPENCLAW_DIR/openclaw.pid\"\nMAX_STARTUP_TIME=60\n\n# Colors for output\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nNC='\\033[0m'\n\n# Logging function\nlog() {\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $1\" | tee -a \"$LOG_FILE\"\n}\n\nlog \"рҹҡҖ OpenClaw Optimized Startup\"\nlog \"   Memory: 1.5GB limit\"\nlog \"   Config: SSOT compliant\"\n\n# в”Җв”Җв”Җ STEP 1: Load SSOT Keys from Keychain в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nlog \"рҹ”җ Loading SSOT API keys from Keychain...\"\n\nexport ZAI_API_KEY=$(security find-generic-password -s \"z.ai\" -a \"openclaw\" -w 2>/dev/null || echo \"\")\nexport GROQ_API_KEY=$(security find-generic-password -s \"SSOT_AI_GROQ\" -w 2>/dev/null || echo \"\")\nexport DEEPSEEK_API_KEY=$(security find-generic-password -s \"SSOT_AI_DEEPSEEK\" -w 2>/dev/null || echo \"\")\n\n# Verify primary key\nif [ -z \"$ZAI_API_KEY\" ]; then\n    log \"${RED}вқҢ ERROR: ZAI_API_KEY not found in Keychain${NC}\"\n    log \"   Add it with: security add-generic-password -a 'openclaw' -s 'z.ai' -w 'your-key'\"\n    exit 1\nfi\n\nlog \"${GREEN}вң“${NC} ZAI_API_KEY loaded (length: ${#ZAI_API_KEY})\"\nif [ -n \"$GROQ_API_KEY\" ]; then\n    log \"${GREEN}вң“${NC} GROQ_API_KEY loaded (length: ${#GROQ_API_KEY})\"\nfi\nif [ -n \"$DEEPSEEK_API_KEY\" ]; then\n    log \"${GREEN}вң“${NC} DEEPSEEK_API_KEY loaded\"\nfi\n\n# в”Җв”Җв”Җ STEP 2: Environment Setup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n# CRITICAL: Set PATH to include NVM node and bun BEFORE running openclaw\nexport PATH=\"$HOME/.nvm/versions/node/v22.16.0/bin:$HOME/.bun/bin:/usr/local/bin:/usr/bin:/bin:$PATH\"\nexport NODE_ENV=production\n# NODE_OPTIONS removed - OpenClaw handles memory internally via config\nexport OPENCLAW_HOST=127.0.0.1\nexport OPENCLAW_PORT=18789\n\n# Verify node is accessible\nif ! command -v node &> /dev/null; then\n    log \"${RED}вқҢ ERROR: node not found in PATH${NC}\"\n    exit 1\nfi\nlog \"${GREEN}вң“${NC} Node.js: $(node --version)\"\n\n# в”Җв”Җв”Җ STEP 3: Clean Up Old Processes в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nlog \"рҹ§№ Cleaning up old processes...\"\npkill -9 -f \"openclaw.*gateway\" 2>/dev/null || true\nsleep 2\n\n# Clear temp/cache files\nrm -rf \"$OPENCLAW_DIR/cache/\"* 2>/dev/null || true\nrm -rf \"$OPENCLAW_DIR/temp/\"* 2>/dev/null || true\n\n# в”Җв”Җв”Җ STEP 4: Start OpenClaw Gateway в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\ncd \"$OPENCLAW_DIR\" || exit 1\n\nlog \"рҹҡҖ Starting OpenClaw Gateway...\"\n\n# Use bun to run OpenClaw\nnohup ~/.bun/bin/openclaw gateway >> \"$OPENCLAW_DIR/logs/gateway.log\" 2>&1 &\n\nGATEWAY_PID=$!\necho \"$GATEWAY_PID\" > \"$PID_FILE\"\nlog \"   PID: $GATEWAY_PID\"\nlog \"   Port: 18789\"\n\n# в”Җв”Җв”Җ STEP 5: Wait for Startup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nlog \"вҸі Waiting for gateway to start...\"\n\nfor i in $(seq 1 $MAX_STARTUP_TIME); do\n    # Check if process is still running\n    if ! ps -p $GATEWAY_PID > /dev/null 2>&1; then\n        log \"${RED}вқҢ Process died during startup${NC}\"\n        log \"   Last 20 log lines:\"\n        tail -20 \"$OPENCLAW_DIR/logs/gateway.log\" 2>/dev/null || true\n        exit 1\n    fi\n\n    # Check if port is listening\n    if lsof -i :18789 > /dev/null 2>&1; then\n        MEM=$(ps -o rss= -p $GATEWAY_PID 2>/dev/null | awk '{print int($1/1024)}')\n        log \"${GREEN}вң… Gateway started successfully!${NC}\"\n        log \"   Memory: ${MEM}MB\"\n        log \"   Port: 18789\"\n        log \"   Config: Optimized for 8GB RAM\"\n        exit 0\n    fi\n\n    echo -n \".\"\n    sleep 1\ndone\n\n# Timeout\nlog \"\"\nlog \"${RED}вқҢ Gateway failed to start within ${MAX_STARTUP_TIME}s${NC}\"\nlog \"   Last 20 log lines:\"\ntail -20 \"$OPENCLAW_DIR/logs/gateway.log\" 2>/dev/null || true\nkill -9 $GATEWAY_PID 2>/dev/null || true\nexit 1","cwd":"/Users/ahmadabdullah/.openclaw/workspace"},"isError":false,"timestamp":1773243886199}}
