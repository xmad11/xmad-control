{"type":"message","id":"47fbc59b","parentId":"dbab40eb","timestamp":"2026-03-11T16:31:43.638Z","message":{"role":"assistant","content":[{"type":"text","text":"Perfect! The dashboard already has chat. Let me check what the current chat implementation does and update it to connect to OpenClaw properly with STT/TTS:"},{"type":"toolCall","id":"call_abdb5823568148f1afbbdf0f","name":"read","arguments":{"path":"/Users/ahmadabdullah/Desktop/xmad-control-center/app.js","limit":50,"offset":510}},{"type":"toolCall","id":"call_84bff4841abc49acae2df5e0","name":"write","arguments":{"content":"// ============================================\n// OPENCLAW AI CHAT - ENHANCED VERSION\n// Replace the existing sendAIMessage() and add voice features\n// ============================================\n\nlet chatMode = 'whatsapp'; // 'whatsapp' or 'direct'\nlet recognition = null;\nlet isRecording = false;\nlet synthesis = window.speechSynthesis;\n\n// Send AI message to OpenClaw\nasync function sendAIMessage() {\n    const input = document.getElementById('aiChatInput');\n    const message = input.value.trim();\n    if (!message) return;\n\n    const messagesDiv = document.getElementById('aiChatMessages');\n    \n    // Add user message\n    addMessage('user', message);\n    input.value = '';\n\n    // Add typing indicator\n    const typingDiv = document.createElement('div');\n    typingDiv.className = 'ai-message assistant';\n    typingDiv.id = 'typingIndicator';\n    typingDiv.innerHTML = '<div class=\"msg-text\">...</div><div class=\"msg-time\">typing</div>';\n    messagesDiv.appendChild(typingDiv);\n    messagesDiv.scrollTop = messagesDiv.scrollHeight;\n\n    try {\n        // Send to OpenClaw gateway\n        const response = await fetch('http://localhost:18789/api/message', {\n            method: 'POST',\n            headers: { 'Content-Type': 'application/json' },\n            body: JSON.stringify({\n                message: message,\n                channel: chatMode,\n                sessionKey: 'xmad-dashboard'\n            })\n        });\n\n        // Remove typing indicator\n        const indicator = document.getElementById('typingIndicator');\n        if (indicator) indicator.remove();\n\n        if (response.ok) {\n            const data = await response.json();\n            \n            if (data.reply) {\n                addMessage('assistant', data.reply);\n                \n                // TTS: Speak the response\n                speakText(data.reply);\n            }\n        } else {\n            addMessage('assistant', 'вқҢ Error: Could not connect to OpenClaw');\n        }\n    } catch (error) {\n        const indicator = document.getElementById('typingIndicator');\n        if (indicator) indicator.remove();\n        addMessage('assistant', 'вқҢ Error: ' + error.message);\n    }\n}\n\n// Add message to chat\nfunction addMessage(type, text) {\n    const messagesDiv = document.getElementById('aiChatMessages');\n    const msgDiv = document.createElement('div');\n    msgDiv.className = `ai-message ${type}`;\n    \n    const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });\n    \n    msgDiv.innerHTML = `\n        <div class=\"msg-text\">${escapeHtml(text)}</div>\n        <div class=\"msg-time\">${time}</div>\n    `;\n    \n    messagesDiv.appendChild(msgDiv);\n    messagesDiv.scrollTop = messagesDiv.scrollHeight;\n}\n\n// Escape HTML\nfunction escapeHtml(text) {\n    const div = document.createElement('div');\n    div.textContent = text;\n    return div.innerHTML;\n}\n\n// ============================================\n// VOICE FEATURES (STT/TTS)\n// ============================================\n\n// Toggle voice recording\nfunction toggleVoiceRecording() {\n    const btn = document.getElementById('voiceRecordBtn');\n    \n    if (!isRecording) {\n        // Start recording\n        startRecording();\n        if (btn) {\n            btn.style.background = 'var(--red-500)';\n            btn.innerHTML = 'вҸ№';\n        }\n    } else {\n        // Stop recording\n        stopRecording();\n    }\n}\n\n// Start voice recording\nfunction startRecording() {\n    isRecording = true;\n    \n    if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {\n        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;\n        recognition = new SpeechRecognition();\n        \n        recognition.continuous = false;\n        recognition.interimResults = false;\n        recognition.lang = 'en-US';\n        \n        recognition.onresult = (event) => {\n            const transcript = event.results[0][0].transcript;\n            document.getElementById('aiChatInput').value = transcript;\n            \n            // Auto-send after recording\n            setTimeout(() => {\n                sendAIMessage();\n            }, 500);\n        };\n        \n        recognition.onerror = (event) => {\n            console.error('Speech recognition error:', event.error);\n            stopRecording();\n            addMessage('assistant', 'вқҢ Voice recognition error: ' + event.error);\n        };\n        \n        recognition.onend = () => {\n            stopRecording();\n        };\n        \n        recognition.start();\n    } else {\n        addMessage('assistant', 'вқҢ Speech recognition not supported in this browser');\n        stopRecording();\n    }\n}\n\n// Stop voice recording\nfunction stopRecording() {\n    isRecording = false;\n    \n    const btn = document.getElementById('voiceRecordBtn');\n    if (btn) {\n        btn.style.background = '';\n        btn.innerHTML = 'рҹҺӨ';\n    }\n    \n    if (recognition) {\n        recognition.stop();\n        recognition = null;\n    }\n}\n\n// TTS: Speak text\nfunction speakText(text) {\n    if (!synthesis) return;\n    \n    // Cancel any ongoing speech\n    synthesis.cancel();\n    \n    const utterance = new SpeechSynthesisUtterance(text);\n    utterance.lang = 'en-US';\n    utterance.rate = 1.0;\n    utterance.pitch = 1.0;\n    utterance.volume = 0.8;\n    \n    synthesis.speak(utterance);\n}\n\n// Set chat mode (WhatsApp or Direct)\nfunction setChatMode(mode) {\n    chatMode = mode;\n    const modeDisplay = document.getElementById('chatModeDisplay');\n    \n    if (modeDisplay) {\n        modeDisplay.textContent = mode === 'whatsapp' ? 'рҹ“ұ WhatsApp' : 'рҹ’¬ Direct';\n    }\n    \n    // Update button styles\n    const whatsappBtn = document.getElementById('modeWhatsApp');\n    const directBtn = document.getElementById('modeDirect');\n    \n    if (whatsappBtn && directBtn) {\n        whatsappBtn.classList.toggle('active', mode === 'whatsapp');\n        directBtn.classList.toggle('active', mode === 'direct');\n    }\n}\n\n// ============================================\n// HTML ADDITIONS\n// Add this to the AI chat input section in index.html\n// ============================================\n\n/*\n<div class=\"ai-chat-input\" style=\"display:flex; flex-direction:column; gap:0.5rem;\">\n    <div style=\"display:flex; gap:0.4rem; align-items:center;\">\n        <button id=\"voiceRecordBtn\" class=\"glass-btn sm ghost\" onclick=\"toggleVoiceRecording()\" title=\"Voice input\">\n            рҹҺӨ\n        </button>\n        <input type=\"text\" class=\"glass-input\" id=\"aiChatInput\" placeholder=\"Type or speak...\" onkeypress=\"if(event.key==='Enter')sendAIMessage()\" style=\"flex:1;\">\n        <button class=\"glass-btn sm primary\" onclick=\"sendAIMessage()\">Send</button>\n    </div>\n    <div style=\"display:flex; gap:0.4rem; font-size:0.7rem;\">\n        <button id=\"modeWhatsApp\" class=\"chip-btn active\" onclick=\"setChatMode('whatsapp')\">рҹ“ұ WhatsApp</button>\n        <button id=\"modeDirect\" class=\"chip-btn\" onclick=\"setChatMode('direct')\">рҹ’¬ Direct</button>\n        <span style=\"margin-left:auto; color:var(--text-muted);\" id=\"chatModeDisplay\">рҹ“ұ WhatsApp</span>\n    </div>\n</div>\n*/\n\n// ============================================\n// CSS ADDITIONS\n// Add to styles.css\n// ============================================\n\n/*\n.chip-btn {\n    background: rgba(255,255,255,0.05);\n    border: 1px solid rgba(255,255,255,0.1);\n    color: var(--text-secondary);\n    padding: 0.3rem 0.6rem;\n    border-radius: 15px;\n    font-size: 0.7rem;\n    cursor: pointer;\n    transition: all 0.2s;\n}\n\n.chip-btn:hover {\n    background: rgba(255,255,255,0.1);\n}\n\n.chip-btn.active {\n    background: var(--primary-500);\n    color: white;\n    border-color: var(--primary-500);\n}\n\n#voiceRecordBtn {\n    transition: all 0.3s;\n}\n\n#voiceRecordBtn:active {\n    transform: scale(0.95);\n}\n*/\n","path":"/Users/ahmadabdullah/Desktop/xmad-control-center/ENHANCED_AI_CHAT.js"}}],"api":"anthropic-messages","provider":"zai","model":"glm-4.7","usage":{"input":97000,"output":1829,"cacheRead":1152,"cacheWrite":0,"totalTokens":99981,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773246680931}}
{"type":"message","id":"27c11618","parentId":"47fbc59b","timestamp":"2026-03-11T16:31:43.645Z","message":{"role":"toolResult","toolCallId":"call_abdb5823568148f1afbbdf0f","toolName":"read","content":[{"type":"text","text":"}\n\nfunction sendAIMessage() {\n    const input = document.getElementById('aiChatInput');\n    const messages = document.getElementById('aiChatMessages');\n\n    if (!input.value.trim()) return;\n\n    const userMessage = input.value.trim();\n\n    messages.innerHTML += `\n        <div class=\"ai-message user\">\n            <div class=\"msg-text\">${escapeHtml(userMessage)}</div>\n            <div class=\"msg-time\">Just now</div>\n        </div>\n    `;\n\n    input.value = '';\n    messages.scrollTop = messages.scrollHeight;\n\n    // Send to API\n    fetch(`http://localhost:${CONFIG.apiPort}/api/openclaw/message`, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ message: userMessage })\n    })\n    .then(r => r.json())\n    .then(result => {\n        messages.innerHTML += `\n            <div class=\"ai-message assistant\">\n                <div class=\"msg-text\">${escapeHtml(result.response || 'Processing...')}</div>\n                <div class=\"msg-time\">Just now</div>\n            </div>\n        `;\n        messages.scrollTop = messages.scrollHeight;\n    })\n    .catch(() => {\n        messages.innerHTML += `\n            <div class=\"ai-message assistant\">\n                <div class=\"msg-text\">OpenClaw is offline. Please check service status.</div>\n                <div class=\"msg-time\">Just now</div>\n            </div>\n        `;\n    });\n}\n\n// ============================================\n// TASKS\n// ============================================\n\n\n[454 more lines in file. Use offset=560 to continue.]"}],"isError":false,"timestamp":1773246703642}}
