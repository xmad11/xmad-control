:16] вң“ PID:11837 | Mem:28MB | Healthy\n[2026-03-11 01:47:46] вң“ PID:11837 | Mem:28MB | Healthy\n[2026-03-11 01:48:16] вң“ PID:11837 | Mem:28MB | Healthy\n[2026-03-11 01:48:46] вң“ PID:11837 | Mem:28MB | Healthy\n[2026-03-11 01:49:17] вң“ PID:11837 | Mem:28MB | Healthy\n[2026-03-11 01:49:47] вң“ PID:11837 | Mem:28MB | Healthy\n[2026-03-11 01:50:17] вң“ PID:11837 | Mem:28MB | Healthy\n[2026-03-11 01:50:47] вң“ PID:11837 | Mem:28MB | Healthy\n[2026-03-11 01:51:17] вң“ PID:11837 | Mem:28MB | Healthy\n[2026-03-11 01:51:47] вң“ PID:11837 | Mem:28MB | Healthy\n[2026-03-11 01:52:17] вң“ PID:11837 | Mem:28MB | Healthy","cwd":"/Users/ahmadabdullah/.openclaw/workspace"},"isError":false,"timestamp":1773243724885}}
{"type":"message","id":"e641d8ca","parentId":"7b9c1b36","timestamp":"2026-03-11T15:42:14.493Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_3194782ea5794355b8661755","name":"read","arguments":{"path":"/Users/ahmadabdullah/.openclaw/scripts/watchdog.sh"}},{"type":"toolCall","id":"call_78e9de092e7d4895a22b68eb","name":"exec","arguments":{"command":"pgrep -f \"watchdog.*openclaw\" | head -5"}},{"type":"toolCall","id":"call_00181e8107a145c789e8df74","name":"exec","arguments":{"command":"launchctl list | grep -i watchdog"}}],"api":"anthropic-messages","provider":"zai","model":"glm-4.7","usage":{"input":89473,"output":63,"cacheRead":1152,"cacheWrite":0,"totalTokens":90688,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773243724891}}
{"type":"message","id":"909efed5","parentId":"e641d8ca","timestamp":"2026-03-11T15:42:14.565Z","message":{"role":"toolResult","toolCallId":"call_3194782ea5794355b8661755","toolName":"read","content":[{"type":"text","text":"#!/bin/bash\n# ============================================================\n# OpenClaw Smart Watchdog - SSOT Version\n# Location: ~/.openclaw/scripts/watchdog.sh\n# Monitors: Memory, Health, Crashes, Freezes\n# Reports: ~/Desktop/xmad-control-center/openclaw/\n# ============================================================\n\n# CRITICAL: Set PATH to include NVM node and bun\nexport PATH=\"$HOME/.nvm/versions/node/v22.16.0/bin:$HOME/.bun/bin:/usr/local/bin:/usr/bin:/bin:$PATH\"\n\nMAX_MEM=1400\nCHECK_INTERVAL=30\nHEALTH_URL=\"http://127.0.0.1:18789/\"\nOPENCLAW_DIR=\"$HOME/.openclaw\"\nXMAD_DIR=\"$HOME/Desktop/xmad-control-center/openclaw\"\nLOG_FILE=\"$XMAD_DIR/logs/watchdog.log\"\nREPORT_FILE=\"$XMAD_DIR/watchdog/status.json\"\nLAUNCH_AGENT_LABEL=\"com.openclaw.agent\"\nLAUNCH_AGENT_PLIST=\"$HOME/Library/LaunchAgents/${LAUNCH_AGENT_LABEL}.plist\"\nRESTART_COUNT=0\nMAX_RESTARTS_PER_HOUR=10\nCONSECUTIVE_FAILURES=0\n\n# Ensure directories exist\nmkdir -p \"$XMAD_DIR/logs\" \"$XMAD_DIR/watchdog\"\n\nlog() {\n  local msg=\"[$(date '+%Y-%m-%d %H:%M:%S')] $1\"\n  echo \"$msg\"\n  echo \"$msg\" >> \"$LOG_FILE\" 2>/dev/null || true\n}\n\n# Write status report for XMAD Control Center\nwrite_report() {\n  local status=\"$1\"\n  local pid=\"$2\"\n  local mem=\"$3\"\n  local message=\"$4\"\n  cat > \"$REPORT_FILE\" << EOF\n{\n  \"timestamp\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\n  \"status\": \"$status\",\n  \"pid\": \"$pid\",\n  \"memory_mb\": \"$mem\",\n  \"message\": \"$message\",\n  \"restart_count\": $RESTART_COUNT,\n  \"consecutive_failures\": $CONSECUTIVE_FAILURES\n}\nEOF\n}\n\nget_pid()    { pgrep -f \"openclaw\" | grep -v grep | head -1; }\nget_mem_mb() { local p=$1; [ -z \"$p\" ] && echo \"0\" && return; ps -o rss= -p \"$p\" 2>/dev/null | awk '{print int($1/1024)}' || echo \"0\"; }\ncheck_health() { curl -s -f -m 5 \"$HEALTH_URL\" > /dev/null 2>&1; }\nis_un_state()  { local p=$1; [ -z \"$p\" ] && return 1; [[ \"$(ps -o stat= -p \"$p\" 2>/dev/null)\" == *\"U\"* ]]; }\n\nrestart_gateway() {\n  local reason=$1\n  log \"вҡ пёҸ  RESTART вҖ” $reason (attempt $((RESTART_COUNT+1))/$MAX_RESTARTS_PER_HOUR)\"\n  RESTART_COUNT=$((RESTART_COUNT + 1))\n\n  if [ $RESTART_COUNT -gt $MAX_RESTARTS_PER_HOUR ]; then\n    log \"вқҢ Too many restarts вҖ” pausing 10 min\"\n    write_report \"paused\" \"\" \"\" \"Too many restarts, cooling down\"\n    sleep 600\n    RESTART_COUNT=0\n    return\n  fi\n\n  pkill -9 -f \"openclaw\" 2>/dev/null || true\n  sleep 3\n\n  # Start via LaunchAgent (proper SSOT method)\n  launchctl kickstart gui/$(id -u)/$LAUNCH_AGENT_LABEL 2>/dev/null || \\\n    bash \"$OPENCLAW_DIR/scripts/start-optimized.sh\" >> \"$LOG_FILE\" 2>&1 &\n\n  log \"вҸі Waiting for gateway...\"\n  for i in $(seq 1 45); do\n    if lsof -i :18789 > /dev/null 2>&1; then\n      local NEW_PID MEM\n      NEW_PID=$(get_pid)\n      MEM=$(get_mem_mb \"$NEW_PID\")\n      log \"вң… Up вҖ” PID:$NEW_PID | Mem:${MEM}MB\"\n      write_report \"running\" \"$NEW_PID\" \"$MEM\" \"Gateway restarted successfully\"\n      CONSECUTIVE_FAILURES=0\n      return\n    fi\n    sleep 1\n  done\n  log \"вқҢ Gateway did not come up within 45s\"\n  write_report \"error\" \"\" \"\" \"Gateway failed to start\"\n}\n\nlog \"в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\"\nlog \"рҹҗ• Watchdog started | Limit:${MAX_MEM}MB | Interval:${CHECK_INTERVAL}s\"\nlog \"   Reports: $XMAD_DIR/watchdog/\"\nlog \"в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\"\n\nLAST_RESET=$(date +%s)\n\nwhile true; do\n  PID=$(get_pid)\n\n  if [ -z \"$PID\" ]; then\n    log \"вқҢ Process gone\"\n    write_report \"down\" \"\" \"\" \"Process not found\"\n    restart_gateway \"Process not found\"\n    sleep $CHECK_INTERVAL; continue\n  fi\n\n  if is_un_state \"$PID\"; then\n    log \"вҡ пёҸ  UN state (I/O hang)\"\n    write_report \"hung\" \"$PID\" \"\" \"I/O hang detected\"\n    restart_gateway \"UN state\"\n    sleep $CHECK_INTERVAL; continue\n  fi\n\n  MEM=$(get_mem_mb \"$PID\")\n  if [ \"$MEM\" -gt \"$MAX_MEM\" ]; then\n    log \"вҡ пёҸ  Memory ${MEM}MB > ${MAX_MEM}MB limit\"\n    write_report \"memory_warning\" \"$PID\" \"$MEM\" \"Memory limit exceeded\"\n    restart_gateway \"Memory exceeded\"\n    sleep $CHECK_INTERVAL; continue\n  fi\n\n  if ! check_health; then\n    CONSECUTIVE_FAILURES=$((CONSECUTIVE_FAILURES + 1))\n    log \"вҡ пёҸ  Health fail ($CONSECUTIVE_FAILURES/3)\"\n    write_report \"health_fail\" \"$PID\" \"$MEM\" \"Health check failed ($CONSECUTIVE_FAILURES/3)\"\n    if [ $CONSECUTIVE_FAILURES -ge 3 ]; then\n      restart_gateway \"Health check 3x fail\"\n      CONSECUTIVE_FAILURES=0\n    fi\n  else\n    [ $CONSECUTIVE_FAILURES -gt 0 ] && log \"вң… Recovered\"\n    CONSECUTIVE_FAILURES=0\n    log \"вң“ PID:$PID | Mem:${MEM}MB | Healthy\"\n    write_report \"running\" \"$PID\" \"$MEM\" \"All checks passed\"\n  fi\n\n  NOW=$(date +%s)\n  if [ $((NOW - LAST_RESET)) -gt 3600 ]; then\n    [ $RESTART_COUNT -gt 0 ] && log \"рҹ”„ Hour reset (was $RESTART_COUNT restarts)\"\n    RESTART_COUNT=0; LAST_RESET=$NOW\n  fi\n\n  sleep $CHECK_INTERVAL\ndone\n"}],"isError":false,"timestamp":1773243734496}}
