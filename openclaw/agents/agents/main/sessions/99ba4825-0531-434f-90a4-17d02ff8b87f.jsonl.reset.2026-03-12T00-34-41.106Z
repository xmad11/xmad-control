{"type":"message","id":"777c8735","parentId":"69bb66e4","timestamp":"2026-03-11T21:21:45.447Z","message":{"role":"toolResult","toolCallId":"call_8bdd5578270349e6823356b3","toolName":"exec","content":[{"type":"text","text":"/* в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\n   APP HEADER - Restaurant Platform 2025-2026\n   Uses NavigationContext for panel state (menu/theme)\n   Renders in root layout only - NEVER in client components\n   в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ */\n\n\"use client\"\n\nimport { Bars3BottomRightIcon } from \"@/components/icons\"\nimport { BackButton } from \"@/components/navigation/BackButton\"\nimport { useNavigation } from \"@/components/navigation/NavigationProvider\"\nimport { THEME_ICONS } from \"@/components/theme-constants\"\nimport { type ThemeMode, useTheme } from \"@/context/ThemeContext\"\nimport { usePathname } from \"next/navigation\"\nimport { memo, useCallback, useEffect, useMemo, useRef, useState } from \"react\"\nimport LanguageToggle from \"./LanguageToggle\"\nimport SideMenu from \"./SideMenu\"\nimport ThemeModal from \"./ThemeModal\"\n\nexport type UserRole = \"guest\" | \"user\" | \"owner\" | \"admin\"\n\nexport interface AppHeaderProps {\n  role?: UserRole\n  showRoleBadge?: boolean\n  title?: string\n  subtitle?: string\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   Component constants - defined outside render to prevent recreation\n   в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\nconst SCROLL_HIDE_THRESHOLD = 50\nconst SCROLL_GLASS_THRESHOLD = 20\n\nfunction AppHeaderComponent({\n  role: _role = \"guest\",\n  showRoleBadge: _showRoleBadge = false,\n  title,\n  subtitle,\n}: AppHeaderProps) {\n  const { mode, mounted: themeMounted } = useTheme()\n  const { activePanel, openMenu, openTheme, closeAll, showBackButton } = useNavigation()\n  const pathname = usePathname()\n  const [visible, setVisible] = useState(true)\n  const [isScrolled, setIsScrolled] = useState(false)\n  const lastScrollY = useRef(0)\n  const ticking = useRef(false)\n\n  // Only show theme icon on home page\n  const isHomePage = pathname === \"/\""}],"details":{"status":"completed","exitCode":0,"durationMs":218,"aggregated":"/* в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\n   APP HEADER - Restaurant Platform 2025-2026\n   Uses NavigationContext for panel state (menu/theme)\n   Renders in root layout only - NEVER in client components\n   в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ */\n\n\"use client\"\n\nimport { Bars3BottomRightIcon } from \"@/components/icons\"\nimport { BackButton } from \"@/components/navigation/BackButton\"\nimport { useNavigation } from \"@/components/navigation/NavigationProvider\"\nimport { THEME_ICONS } from \"@/components/theme-constants\"\nimport { type ThemeMode, useTheme } from \"@/context/ThemeContext\"\nimport { usePathname } from \"next/navigation\"\nimport {