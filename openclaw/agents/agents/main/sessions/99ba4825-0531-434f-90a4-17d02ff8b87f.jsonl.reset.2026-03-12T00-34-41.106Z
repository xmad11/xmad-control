{"type":"message","id":"20b1f0da","parentId":"9383cbcd","timestamp":"2026-03-11T15:40:01.370Z","message":{"role":"assistant","content":[{"type":"text","text":"Let me check the XMAD Control Center for OpenClaw files:"},{"type":"toolCall","id":"call_55e62b09e1494ea3a686637b","name":"read","arguments":{"path":"/Users/ahmadabdullah/Desktop/xmad-control-center/server.js","limit":200}},{"type":"toolCall","id":"call_a1b8c23f2d624fdf989e7240","name":"exec","arguments":{"command":"ls -la ~/Desktop/xmad-control-center/"}},{"type":"toolCall","id":"call_043a4bd7a1934364af508ca7","name":"exec","arguments":{"command":"ls -la ~/Desktop/xmad-control-center/openclaw/ 2>/dev/null || echo \"No openclaw dir found\""}}],"api":"anthropic-messages","provider":"zai","model":"glm-4.7","usage":{"input":361,"output":96,"cacheRead":86912,"cacheWrite":0,"totalTokens":87369,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773243596490}}
{"type":"message","id":"22a866a4","parentId":"20b1f0da","timestamp":"2026-03-11T15:40:01.603Z","message":{"role":"toolResult","toolCallId":"call_55e62b09e1494ea3a686637b","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * XMAD Control Center v3.0 - Enhanced Server\n * OpenClaw + Guardian + Memory + Backups + Tools\n * SSOT Compliant - No hardcoded secrets\n */\n\nconst http = require('http');\nconst { exec, execSync } = require('child_process');\nconst fs = require('fs');\nconst path = require('path');\nconst os = require('os');\n\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// CONFIGURATION CONSTANTS\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nconst VERSION = '3.0';\nconst PORT = 8765;\nconst HOME = os.homedir();\n\n// Directory paths - configurable via environment variables\nconst GUARDIAN_DIR = process.env.GUARDIAN_DIR || path.join(HOME, '.guardian-orchestrator-2026');\nconst OPENCLAW_DIR = process.env.OPENCLAW_DIR || path.join(HOME, '.openclaw');\nconst BACKUPS_DIR = process.env.BACKUPS_DIR || path.join(HOME, '.guardian-orchestrator', 'backups', 'dashboard');\nconst DESKTOP_DIR = path.join(HOME, 'Desktop');\nconst IMPORTANT_DOCS_DIR = process.env.IMPORTANT_DOCS_DIR || path.join(DESKTOP_DIR, 'important-docs');\nconst XMAD_DIR = path.join(DESKTOP_DIR, 'xmad-control-center');\n\n// Ensure directories exist\nfs.mkdirSync(BACKUPS_DIR, { recursive: true });\n\nfunction runCommand(cmd) {\n    try {\n        const output = execSync(cmd, {\n            encoding: 'utf8',\n            timeout: 30000,\n            maxBuffer: 1024 * 1024,\n            killSignal: 'SIGKILL'\n        });\n        return { success: true, output: output.trim() };\n    } catch (error) {\n        return { success: false, output: error.stderr || error.message };\n    }\n}\n\n// Tailscale handlers\nconst tailscale = {\n    status: () => {\n        const result = runCommand('tailscale status --json 2>/dev/null || echo \"{}\"');\n        try {\n            const data = JSON.parse(result.output);\n            const online = data?.Self?.Online || false;\n            const ip = data?.Self?.TailscaleIPs?.[0] || '-';\n            const peers = Object.keys(data?.Peer || {}).length;\n            return { online, ip, devices: peers + 1, success: true };\n        } catch {\n            const ipResult = runCommand('tailscale ip 2>/dev/null');\n            return { online: ipResult.output.includes('100.'), ip: ipResult.output.trim() || '-', devices: '-', success: true };\n        }\n    },\n    start: () => runCommand('tailscale up 2>&1'),\n    stop: () => runCommand('tailscale down 2>&1')\n};\n\n// SSH handlers\nconst ssh = {\n    status: () => {\n        const result = runCommand('netstat -an | grep \"\\\\.22 \" | grep -q LISTEN && echo \"On\" || echo \"Off\"');\n        return { online: result.output.trim() === 'On', success: true };\n    },\n    start: () => ({ success: true, output: 'SSH is managed by macOS System Preferences' }),\n    stop: () => ({ success: true, output: 'SSH is managed by macOS System Preferences' })\n};\n\n// OpenClaw handlers - ENHANCED\nconst openclaw = {\n    status: () => {\n        const pidResult = runCommand('pgrep -f \"openclaw-gateway\" || echo \"\"');\n        const pid = pidResult.output.trim();\n\n        const portResult = runCommand('lsof -i :18789 2>/dev/null | grep -q LISTEN && echo \"online\" || echo \"offline\"');\n\n        let memory = 0;\n        let version = 'unknown';\n        let whatsapp = 'checking';\n        let watchdog = 'stopped';\n\n        if (pid) {\n            const memResult = runCommand(`ps -o rss= -p ${pid} 2>/dev/null || echo \"0\"`);\n            memory = Math.round(parseInt(memResult.output.trim()) / 1024);\n        }\n\n        const versionResult = runCommand('openclaw --version 2>/dev/null || echo \"unknown\"');\n        version = versionResult.output.trim();\n\n        const whatsappResult = runCommand('pgrep -f \"whatsapp\" > /dev/null 2>&1 && echo \"connected\" || echo \"checking\"');\n        whatsapp = whatsappResult.output.trim();\n\n        const watchdogResult = runCommand('pgrep -f \"watchdog.*openclaw\" > /dev/null 2>&1 && echo \"running\" || echo \"stopped\"');\n        watchdog = watchdogResult.output.trim();\n\n        return {\n            online: portResult.output.trim() === 'online',\n            pid: pid || null,\n            memory,\n            version,\n            port: 18789,\n            whatsapp,\n            watchdog,\n            success: true\n        };\n    },\n    start: () => runCommand('bash ~/.openclaw/scripts/start-production.sh 2>&1'),\n    stop: () => {\n        runCommand('pkill -f openclaw-gateway 2>&1');\n        runCommand('pkill -f \"watchdog.*openclaw\" 2>&1');\n        return { success: true, output: 'OpenClaw stopped' };\n    },\n    restart: () => {\n        runCommand('pkill -f openclaw-gateway 2>&1');\n        runCommand('pkill -f \"watchdog.*openclaw\" 2>&1');\n        return runCommand('sleep 2 && bash ~/.openclaw/scripts/start-production.sh 2>&1');\n    },\n    logs: () => {\n        try {\n            const logPath = path.join(process.env.HOME, '.openclaw', 'logs');\n            const files = fs.readdirSync(logPath)\n                .filter(f => f.endsWith('.log'))\n                .map(f => ({ name: f, size: fs.statSync(path.join(logPath, f)).size }));\n            return { success: true, files };\n        } catch {\n            return { success: false, files: [] };\n        }\n    },\n    memory: () => {\n        const pidResult = runCommand('pgrep -f \"openclaw-gateway\" || echo \"\"');\n        const pid = pidResult.output.trim();\n        if (!pid) return { success: false, memory: 0 };\n        const memResult = runCommand(`ps -o rss= -p ${pid} 2>/dev/null || echo \"0\"`);\n        const memory = Math.round(parseInt(memResult.output.trim()) / 1024);\n        return { success: true, memory };\n    }\n};\n\n// Guardian handlers\nconst guardian = {\n    status: () => {\n        const result = runCommand('test -d ~/.guardian-orchestrator-2026 && echo \"exists\" || echo \"not_found\"');\n        return { online: result.output.trim() === 'exists', success: true };\n    },\n    check: () => runCommand('bash ~/.guardian-orchestrator-2026/check_guardian.sh 2>&1 || echo \"Guardian check script not found\"'),\n    logs: () => ({ success: true, output: 'Logs: ~/.guardian-orchestrator-2026/logs/' }),\n    run: (task, project, mode) => {\n        return new Promise((resolve) => {\n            const bridgePath = path.join(GUARDIAN_DIR, 'openclaw-bridge.sh');\n            const projectPath = project || DESKTOP_DIR; // Default to Desktop\n            const modeFlag = mode || '--suggest';\n            const safeTask = task.replace(/\"/g, '\\\\\"');\n\n            exec(\n                `bash \"${bridgePath}\" run \"${safeTask}\" \"${projectPath}\" \"${modeFlag}\"`,\n                { timeout: 15000 },\n                (err, stdout) => {\n                    if (err) {\n                        resolve({ ok: false, error: err.message });\n                        return;\n                    }\n                    try {\n                        resolve(JSON.parse(stdout));\n                    } catch (e) {\n                        resolve({ ok: true, raw: stdout });\n                    }\n                }\n            );\n        });\n    },\n    jobs: () => {\n        return new Promise((resolve) => {\n            const bridgePath = path.join(GUARDIAN_DIR, 'openclaw-bridge.sh');\n            exec(`bash \"${bridgePath}\" list`, { timeout: 5000 }, (err, stdout) => {\n                if (err) {\n                    resolve({ jobs: [] });\n                    return;\n                }\n                try {\n                    resolve(JSON.parse(stdout));\n                } catch (e) {\n                    resolve({ jobs: [] });\n                }\n            });\n        });\n    }\n};\n\n// File handlers (for Memory editor) - SECURED WITH PATH WHITELIST\nconst ALLOWED_PATHS = [\n    HOME,                           // Home directory\n    '/Users/ahmadabdullah/Desktop', // Desktop\n    GUARDIAN_DIR,                  // Guardian config\n    OPENCLAW_DIR,                  // OpenClaw config\n\n[631 more lines in file. Use offset=201 to continue.]"}],"isError":false,"timestamp":1773243601568}}
