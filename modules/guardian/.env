# =============================================================================
# .env — Guardian Orchestrator 2026 Configuration
# SSOT Compliant - Keys retrieved from macOS Keychain
# =============================================================================

# ── SSOT KEY RETRIEVAL ────────────────────────────────────────────────────────
# Keys are retrieved dynamically from macOS Keychain via api-call.sh
# Do NOT store actual keys here - they are fetched at runtime
# Keychain service names: SSOT_AI_GROQ, z.ai, SSOT_AI_GEMINI, etc.

# ── REQUIRED (from Keychain) ──────────────────────────────────────────────────
# GLM_API_KEY - retrieved from Keychain service "z.ai" account "claude-code"
# GROQ_API_KEY - retrieved from Keychain service "SSOT_AI_GROQ"

# ── OPTIONAL (from Keychain) ──────────────────────────────────────────────────
# GEMINI_API_KEY - retrieved from Keychain service "SSOT_AI_GEMINI"
# DEEPSEEK_API_KEY - retrieved from Keychain service "SSOT_AI_DEEPSEEK"

# ── API Base URLs ─────────────────────────────────────────────────────────────
GLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
GROQ_BASE_URL="https://api.groq.com/openai/v1"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# ── Model Names ───────────────────────────────────────────────────────────────
# Guardian (GLM - paid, your orchestrator brain)
GUARDIAN_MODEL="glm-5"
GUARDIAN_FALLBACK="glm-4-plus"

# Groq free agents (2026 stack)
GROQ_CODER_MODEL="moonshotai/kimi-k2-instruct"
GROQ_REASONING_MODEL="openai/gpt-oss-120b"
GROQ_FAST_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
GROQ_WORKHORSE_MODEL="qwen/qwen3-32b"

# Gemini (Google free)
GEMINI_PLANNER_MODEL="gemini-2.5-flash"
GEMINI_FAST_MODEL="gemini-2.0-flash"

# DeepSeek (fallback only - China data laws)
DEEPSEEK_CODER_MODEL="deepseek-chat"
DEEPSEEK_REASONING_MODEL="deepseek-reasoner"

# OpenRouter (last resort fallback)
OPENROUTER_CODER_FREE="qwen/qwen-2.5-coder-32b-instruct:free"

# ── Orchestrator Settings ─────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY=5
COMPLEXITY_HIGH_THRESHOLD=7
COMPLEXITY_MED_THRESHOLD=4
RATE_LIMIT_DIR="/tmp/guardian-rate-limits"
LOG_DIR="${HOME}/.guardian-orchestrator/logs"
CACHE_DIR="${HOME}/.guardian-orchestrator/cache"
