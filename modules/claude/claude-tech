#!/bin/bash
# Tech stack specific Claude commands

case "$1" in
"next")
  ~/.bun/bin/claude --model glm-4.6 --print "Help me with Next.js 16: $2"
  ;;
"biome")
  ~/.bun/bin/claude --model glm-4.6 --print "Help me with Biome formatter: $2"
  ;;
"tailwind")
  ~/.bun/bin/claude --model glm-4.6 --print "Help me with Tailwind 4.1.18: $2"
  ;;
"supabase")
  ~/.bun/bin/claude --model glm-4.6 --print "Help me with Supabase: $2"
  ;;
*)
  ~/.bun/bin/claude --model glm-4.6 --print "Help me with my tech stack: $1 $2"
  ;;
esac